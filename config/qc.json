{
    "workspace": "C:/Users/eliasmichal/Dokumenty/Osobne",

    "input": {
        "file": "SENSOR_DATA.txt",
        "time_format": "gpst_second",
        "time_columns": [0],
        "delimiter": ";",
        "comment_char": "%",
        "columns": [2],
        "merge_strategy": "separate"
    },

    "output": {
        "log_level": "info"
    },

    "qc": {
        "temporal_enabled":    true,
        "stats_enabled":       true,
        "outlier_enabled":     true,
        "sampling_enabled":    true,
        "seasonal_enabled":    true,
        "hurst_enabled":       true,
        "ma_window_size":      1461,
        "significance_level":  0.05,
        "uniformity_threshold": 0.05,
        "min_span_years":      10.0,

        "outlier": {
            "iqr_enabled":      true,
            "iqr_multiplier":   1.5,
            "mad_enabled":      true,
            "mad_multiplier":   3.0,
            "zscore_enabled":   true,
            "zscore_threshold": 3.0
        },

        "seasonal": {
            "enabled":            true,
            "min_years_per_slot": 5,
            "min_month_coverage": 0.5
        }
    },

    "plots": {
        "output_format": "png",
        "qc_coverage":  true,
        "qc_histogram": true,
        "qc_acf":       false
    }
}
