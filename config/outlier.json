{
    "workspace": "C:/Users/eliasmichal/Documents/Osobne",

    "input": {
        "file": "CLIM_DATA_EX1.txt",
        "time_format": "utc",
        "time_columns": [0, 1],
        "delimiter": " ",
        "comment_char": "%",
        "columns": [3],
        "merge_strategy": "separate"
    },

    "output": {
        "log_level": "info"
    },

    "plots": {
        "output_format": "png",
        "time_format": "utc",
        "enabled": {
            
            "time_series":           true,
            "histogram":             true,
            "acf":                   true,
            "qq_plot":               true,
            "boxplot":               true,

            "original_series":       true,
            "adjusted_series":       true,
            "homog_comparison":      true,
            "deseasonalized":        true,
            "seasonal_overlay":      true,
            "residuals_with_bounds": true,
            "outlier_overlay":       false
        }
    },

    "stats": {
        "enabled": true,
        "nan_policy": "skip",
        "hurst": false
    },

    "outlier": {
        "deseasonalization": {
            "strategy": "median_year",
            "ma_window_size": 365,
            "median_year_min_years": 5
        },
        "detection": {
            "method": "mad",
            "iqr_multiplier": 1.5,
            "mad_multiplier": 3.0,
            "zscore_threshold": 3.0
        },
        "replacement": {
            "strategy": "linear",
            "max_fill_length": 0
        }
    }
}