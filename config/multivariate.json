{
    "workspace": "C:/Users/eliasmichal/Documents/Osobne",

    "input": {
        "file": "",
        "time_format": "mjd",
        "delimiter": " ",
        "comment_char": "%"
    },

    "output": {
        "log_level": "info"
    },

    "plots": {
        "output_format": "png",
        "time_format": "mjd",
        "enabled": {
            "correlation_matrix":   false,
            "ccf_heatmap":          false,
            "pca_scree":            false,
            "pca_biplot":           false,
            "pca_scores":           false,
            "mssa_eigenvalues":     false,
            "mssa_components":      false,
            "var_coefficients":     false,
            "var_residuals":        false,
            "granger_heatmap":      false,
            "factor_loadings":      false,
            "cca_scores":           false,
            "lda_boundaries":       false,
            "factor_heatmap":       false,
            "factor_scores":        false,
            "cca_correlations":     true,
            "cca_scatter_pairs":    true,
            "lda_projection":       false,
            "lda_confusion":        false,
            "mahalanobis_dist":     false,
            "mahalanobis_qq":       false,
            "manova_eigenvalues":   false,
            "manova_summary":       false
        }
    },

    "stats": {
        "enabled": true,
        "nan_policy": "skip",
        "hurst": false
    },

    "multivariate": {

        "input": {
            "files": [
                 {
                    "path":         "SYNT_TRAIN_XYZ.txt",
                    "columns":      [2, 3, 4],
                    "time_format":  "gps_total_seconds",
                    "time_columns": [0],
                    "delimiter":    " ",
                    "comment_char": "%"
                },
                {
                    "path":         "SYNT_TRAIN_SPEED.txt",
                    "columns":      [3, 4, 5],
                    "time_format":  "utc",
                    "time_columns": [0, 1],
                    "delimiter":    " ",
                    "comment_char": "%"
                }
            ],
            "sync_strategy":         "inner",
            "sync_tolerance_seconds": 0.50
        },

        "preprocessing": {
            "standardize":      true,
            "apply_gap_filling": true,
            "gap_filling": {
                "strategy":        "linear",
                "max_fill_length": 40
            }
        },

        "ccf": {
            "enabled":            false,
            "max_lag":            10,
            "significance_level": 0.05
        },

        "pca": {
            "enabled":                     false,
            "n_components":                3,
            "variance_threshold":          0.99,
            "use_randomized_svd":          false,
            "randomized_svd_oversampling": 10
        },

        "mssa": {
            "enabled":            false,
            "window":             4,
            "n_components":       4,
            "use_randomized_svd": false
        },

        "var": {
            "enabled":                    false,
            "max_order":                  5,
            "order_criterion":            "aic",
            "granger":                    true,
            "granger_significance_level": 0.01
        },

        "factor": {
            "enabled":   false,
            "n_factors":  2,
            "rotation":  "varimax",
            "max_iter":   500,
            "tolerance":  1e-6
        },

        "cca": {
            "enabled":      true,
            "group_x":      [0, 1, 2],
            "group_y":      [3, 4, 5],
            "n_components": 2
        },

        "lda": {
            "enabled":       false,
            "groups_column": "phase",
            "use_qda":       false
        },

        "mahalanobis": {
            "enabled":            false,
            "robust":             true,
            "significance_level": 0.001
        },

        "manova": {
            "enabled":            false,
            "groups_column":      "phase",
            "significance_level": 0.05
        }
    }
}
