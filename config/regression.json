{
    "workspace": "C:/Users/eliasmichal/Dokumenty/Osobne",

    "input": {
        "file": "SENSOR_DATA.txt",
        "time_format": "gpst",
        "time_columns": [0],
        "delimiter": ";",
        "comment_char": "%",
        "columns": [2],
        "merge_strategy": "separate"
    },

    "output": {
        "log_level": "info"
    },

    "plots": {
        "output_format": "png",
        "time_format": "utc",
        "enabled": {
            "time_series":                  true,
            "histogram":                    true,
            "acf":                          true,
            "qq_plot":                      true,
            "boxplot":                      true,
            "regression_overlay":           true,
            "regression_residuals":         true,
            "regression_qq_bands":          true,
            "regression_cdf_plot":          true,
            "regression_residual_acf":      true,
            "regression_residual_hist":     true,
            "regression_influence":         true,
            "regression_leverage":          true
        }
    },

    "stats": {
        "enabled": true,
        "nan_policy": "skip",
        "hurst": false
    },

    "regression": {
        "gap_filling": {
            "strategy": "linear",
            "max_fill_length": 0
        },

        "method": "polynomial",

        "polynomial_degree": 3,

        "harmonic_terms": 4,
        "period": 365.25,

        "robust": true,
        "robust_iterations": 10,
        "robust_weight_fn": "bisquare",

        "compute_prediction": true,
        "prediction_horizon": 365.25,
        "confidence_level": 0.95,
        "significance_level": 0.05,

        "cv_folds": 10
    }
}
