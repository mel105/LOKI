{
    "workspace": "C:/Users/eliasmichal/Dokumenty/Osobne",

    "output": {
        "log_level": "info"
    },

    "plots": {
        "output_format": "png",
        "spatial_heatmap":   true,
        "spatial_scatter":   true,
        "spatial_variogram": true,
        "spatial_crossval":  true,
        "spatial_variance":  true
    },

    "spatial": {
        "method": "kriging",
        "cross_validate": true,
        "confidence_level": 0.95,

        "input": {
            "file": "SPATIAL_BOH.dat",
            "delimiter": " ",
            "comment_prefix": "#",
            "x_column": 0,
            "y_column": 1,
            "value_columns": [2, 3],
            "no_data_value": -999.9999,
            "no_data_tolerance": 0.01,
            "coordinate_unit": "m"
        },

        "grid": {
            "resolution_x": 300.0,
            "resolution_y": 300.0,
            "x_min": 0.0,
            "x_max": 10000.0,
            "y_min": 0.0,
            "y_max": 10000.0
        },

        "kriging": {
            "method": "simple",
            "known_mean": 14.7,
            "trend_degree": 1,

            "variogram": {
                "model": "spherical",
                "n_lag_bins": 20,
                "max_lag": 0.0,
                "nugget": 0.0,
                "sill": 0.0,
                "range": 0.0
            }
        },

        "idw": {
            "power": 2.0
        },

        "rbf": {
            "kernel": "thin_plate_spline",
            "epsilon": 0.0
        },

        "bspline_surface": {
            "degree_u": 3,
            "degree_v": 3,
            "n_ctrl_u": 4,
            "n_ctrl_v": 4,
            "knot_placement": "uniform"
        }
    }
}
