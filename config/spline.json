{
    "workspace": "C:/Users/eliasmichal/Dokumenty/Osobne",

    "input": {
        "mode": "single_file",
        "file": "SENSOR_DATA.txt",
        "time_format": "gpst_seconds",
        "time_columns": [0],
        "delimiter": ";",
        "comment_char": "%",
        "columns": [2],
        "merge_strategy": "separate"
    },

    "output": {
        "log_level": "info"
    },

    "plots": {
        "output_format": "png",
        "spline_overlay":     true,
        "spline_residuals":   true,
        "spline_basis":       false,
        "spline_knots":       true,
        "spline_cv":          true,
        "spline_diagnostics": false
    },

    "spline": {
        "method":             "bspline",
        "gap_fill_strategy":  "linear",
        "gap_fill_max_length": 0,
        "confidence_level":   0.95,
        "significance_level": 0.05,

        "bspline": {
            "degree":                    3,
            "fit_mode":                  "approximation",
            "n_control_points":          0,
            "n_control_min":             5,
            "n_control_max":             0,
            "knot_placement":            "uniform",
            "cv_folds":                  5,
            "exact_interpolation_max_n": 20
        },

        "nurbs": {
            "degree": 3
        }
    }
}
