{
    "workspace": "C:/Users/eliasmichal/Documents/Osobne",

    "input": {
        "file": "CLIM_DATA_EX1.txt",
        "time_format": "utc",
        "time_columns": [0, 1],
        "delimiter": " ",
        "comment_char": "%",
        "columns": [3],
        "merge_strategy": "separate"
    },

    "output": {
        "log_level": "info"
    },

    "stats": {
        "enabled": true,
        "nan_policy": "skip",
        "hurst": true
    },

    "plots": {
        "output_format": "png",
        "time_series": true,
        "histogram": true,
        "acf": true,
        "pacf_plot": true,
        "arima_residuals": true,
        "arima_residuals_acf": true,
        "arima_forecast": true
    },

    "arima": {
        "gap_fill_strategy": "linear",
        "gap_fill_max_length": 0,

        "deseasonalization": {
            "strategy": "median_year",
            "ma_window_size": 1461,
            "median_year_min_years": 5
        },

        "auto_order": true,
        "p": 1,
        "d": -1,
        "q": 0,
        "max_p": 5,
        "max_q": 5,
        "criterion": "aic",

        "seasonal": {
            "P": 0,
            "D": 0,
            "Q": 0,
            "s": 0
        },

        "fitter": {
            "method": "css",
            "max_iterations": 200,
            "tol": 1e-8
        },

        "compute_forecast": true,
        "forecast_horizon": 1420,
        "confidence_level": 0.95,
        "significance_level": 0.05
    }
}
