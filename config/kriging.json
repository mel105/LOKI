{
    "workspace": "C:/Users/eliasmichal/Dokumenty/Osobne",

    "input": {
        "mode": "single_file",
        "file": "SENSOR_DATA.txt",
        "time_format": "gpst_seconds",
        "time_columns": [0],
        "delimiter": ";",
        "comment_char": "%",
        "columns": [2],
        "merge_strategy": "separate"
    },

    "output": {
        "log_level": "info"
    },

    "plots": {
        "output_format": "png",
        "kriging_variogram":    true,
        "kriging_predictions":  true,
        "kriging_crossval":     true
    },

    "kriging": {
        "mode": "temporal",
        "method": "universal",
        "gap_fill_strategy": "linear",
        "gap_fill_max_length": 0,
        "known_mean": 0.0,
        "trend_degree": 1,
        "cross_validate": true,
        "confidence_level": 0.95,
        "significance_level": 0.05,

        "variogram": {
            "model": "gaussian",
            "n_lag_bins": 20,
            "max_lag": 0.0,
            "nugget": 0.0,
            "sill": 0.0,
            "range": 0.0
        },

        "prediction": {
            "enabled": true,
            "horizon_days": 0.00116,
            "n_steps": 100,
            "target_mjd": []
        }
    }
}
